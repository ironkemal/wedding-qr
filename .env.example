# Google OAuth 2.0 — Google Cloud Console'dan alınan değerler
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# Tek seferlik script ile alınan refresh token
# node scripts/get-refresh-token.js
GOOGLE_REFRESH_TOKEN=1//your-refresh-token

# Google Drive'daki "Düğün" klasörünün ID'si
# Drive'da klasörü açtığında URL'deki son parça: drive.google.com/drive/folders/BURASI
GOOGLE_DRIVE_FOLDER_ID=your-folder-id
